<# foreach (var field in OrderedFields) { #>

<# if (!string.IsNullOrEmpty(field.Tooltip)) { #>
<#= I2 #>[global::UnityEngine.Tooltip("<#= field.Tooltip #>")]
<# } #>
<#= I2 #>[global::UnityEngine.SerializeField]
<#= I2 #>private global::<#= field.TypePart #> <#= field.FieldName #> = null!;
<# } #>

<#= I2 #>void global::Bindings.IView<<#= ViewModelFullName #>>.Initialize(<#= ViewModelFullName #> viewModel)
<#= I2 #>{
