<#= I2 #>}
<# if (!Context.RequireBindImplementation) { #>

<#= I2 #>global::System.Threading.Tasks.ValueTask global::Bindings.IView.BindAsync(global::System.Threading.CancellationToken _)
<#= I2 #>{
<#= I3 #>BindAll();
<#= I3 #>return default;
<#= I2 #>}
<# } #>

<#= I2 #>private void BindAll()
<#= I2 #>{
<#= WriteFieldBindings(I3) #>
<#= WriteMethodBindings(I3) #>
<#= I3 #>OnPostBind();
<#= I3 #>_viewModel.NotifyCompletedBind();
<#= I2 #>}

<#= I2 #>partial void OnPostBind();
<#= I1 #>}
<# if (HasNamespace) { #>
}
<# } #>

