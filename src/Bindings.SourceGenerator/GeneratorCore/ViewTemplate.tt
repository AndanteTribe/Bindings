namespace <#= Context.Namespace #>
{
<# } #>
<# foreach (var (accessibility, typeKeyword, typeName) in Context.ContainingTypes) { #>
<#= accessibility #> partial <#= typeKeyword #> <#= typeName #>
{
<# } #>
<#= Context.Accessibility #> sealed partial class <#= ViewClassName #> : global::Bindings.IMvvmSubscriber<global::Bindings.DebugBindMessage>
{
    void global::Bindings.IMvvmSubscriber<global::Bindings.DebugBindMessage>.OnReceivedMessage(global::Bindings.DebugBindMessage message)
    {
        message.BindTo(this);
<#= WriteFieldBindings("        ") #>
        OnPostBind();
        _viewModel.NotifyCompletedBind();
    }
}
<# foreach (var _ in Context.ContainingTypes) { #>
}
<# } #>
<# if (HasNamespace) { #>
}
